# PCB Defect RAG — Environment Configuration
# Copy to .env and edit as needed:  cp .env.example .env

# --- Knowledge base and index paths ---
KNOWLEDGE_BASE_DIR=knowledge_base
FAISS_INDEX_PATH=faiss_index

# --- Embedding model ---
# Downloaded automatically on first run via Ollama: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# --- Chunking parameters (in tokens) ---
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# --- Retrieval ---
TOP_K=5

# --- Ollama settings ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT=120

# --- CV system ---
CV_SYSTEM_URL=http://localhost:8001/inspection/inspect

# --- FastAPI server ---
API_HOST=0.0.0.0
API_PORT=8000
